# =============================================================================
# Open Pet Registry — environment configuration
# Copy to `.env` for local development:  cp .env.example .env
# Then generate keys:                     npm run keygen
# NEVER commit a real .env file. Secrets must never live in the database or git.
# =============================================================================

# --- Runtime -----------------------------------------------------------------
NODE_ENV=development
# Public base URL of this instance (used in magic-link and QR/poster URLs).
APP_URL=http://localhost:3000

# --- Database (Turso / libSQL) -----------------------------------------------
# Local dev uses an on-disk SQLite file. Production points at a Turso URL.
#   local:       file:./local.db
#   turso:       libsql://your-db-name.turso.io   (+ DATABASE_AUTH_TOKEN)
DATABASE_URL=file:./local.db
# Auth token for hosted libSQL/Turso. Leave blank for a local file DB.
DATABASE_AUTH_TOKEN=

# --- Cryptography (generate with: npm run keygen) ----------------------------
# Active key-encryption-key (KEK) id and value. The KEK wraps per-record data
# keys. It is NEVER stored in the database. Rotate by adding a new versioned
# key below and pointing OPR_KEK_ACTIVE_ID at it.
OPR_KEK_ACTIVE_ID=k1
# Base64 (standard) encoding of a 32-byte key. Example var name pattern:
#   OPR_KEK_<id>=<base64-32-bytes>
OPR_KEK_k1=

# Deterministic index pepper (HMAC key) for blind indexes on chip numbers and
# emails. Separate from the KEK so an index leak never yields decryption power.
# Base64 (standard) encoding of a 32-byte key.
OPR_INDEX_KEY=

# --- Email provider ----------------------------------------------------------
# console = print emails to stdout + a dev outbox file (default in dev)
# smtp    = send via any SMTP host (production; no vendor lock-in)
EMAIL_PROVIDER=console
EMAIL_FROM="Open Pet Registry <no-reply@example.org>"
# Dev outbox: JSON lines file the e2e tests read to fetch magic links.
EMAIL_DEV_OUTBOX=./var/dev-outbox.jsonl
# SMTP settings (only used when EMAIL_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# --- Storage (pet photos) ----------------------------------------------------
# local = filesystem (default, dev)   vercel-blob = Vercel Blob (serverless)   s3 = any S3 bucket
STORAGE_PROVIDER=local
STORAGE_LOCAL_DIR=./var/uploads
# Vercel Blob: token is auto-injected by Vercel when a Blob store is attached.
BLOB_READ_WRITE_TOKEN=
# S3-compatible settings (only used when STORAGE_PROVIDER=s3)
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# --- Rate limiting -----------------------------------------------------------
# memory = in-process (fine for a single instance)   db = shared across instances
RATE_LIMITER=memory

# --- Admin -------------------------------------------------------------------
# Comma-separated owner emails granted access to /admin (demo-data tools, stats).
# In development, any signed-in owner can reach /admin for convenience.
ADMIN_EMAILS=
